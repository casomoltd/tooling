{
  "name": "@casomoltd/tooling",
  "version": "0.17.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/casomoltd/tooling.git"
  },
  "files": [
    "bin/",
    "eslint/",
    "prettier/",
    "commitlint/",
    "knip/",
    "jscpd/",
    "readability/",
    "README.md"
  ],
  "scripts": {
    "check": "node bin/verify-pack.mjs && tsc --noEmit -p hooks/tsconfig.json && node hooks/test.mts",
    "prepare": "husky || true"
  },
  "exports": {
    "./eslint": "./eslint/index.mjs",
    "./eslint-lib": "./eslint/lib.mjs",
    "./prettier": "./prettier/index.js",
    "./commitlint": "./commitlint/index.cjs",
    "./knip": "./knip/index.json",
    "./jscpd": "./jscpd/index.json",
    "./readability": "./readability/index.mjs"
  },
  "bin": {
    "check-tags": "./bin/check-tags.sh",
    "check-version": "./bin/check-version.sh",
    "commit-msg": "./bin/commit-msg.sh",
    "pre-commit": "./bin/pre-commit.sh",
    "pre-push": "./bin/pre-push.sh",
    "readability": "./bin/readability.mjs",
    "screenshot": "./bin/screenshot.mjs"
  },
  "dependencies": {
    "puppeteer": "^24.36.1",
    "text-readability": "^1.1.1"
  },
  "peerDependencies": {
    "@commitlint/cli": ">=20",
    "eslint": ">=9",
    "eslint-config-next": ">=16",
    "eslint-plugin-sonarjs": ">=3",
    "jscpd": ">=4",
    "knip": ">=5"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "husky": "^9.1.7",
    "typescript": "^6.0.3"
  }
}
